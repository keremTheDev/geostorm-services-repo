# GeoStorm-AI canonical local Docker Compose environment example
# Copy to .env for local Docker Compose. Do not put real secrets in this file.

# Container images for docker-compose.images.yml
IMAGE_TAG=latest
GITHUB_CONTAINER_OWNER=replace_me
AI_ENGINE_IMAGE=ghcr.io/replace_me/geostorm-ai-engine:latest
MCP_SERVER_IMAGE=ghcr.io/replace_me/geostorm-mcp-server:latest
ALERT_SERVICE_IMAGE=ghcr.io/replace_me/geostorm-alert-service:latest
FRONTEND_GATEWAY_IMAGE=ghcr.io/replace_me/geostorm-frontend-gateway:latest

# LLM / AI
OPENROUTER_API_KEY=replace_me
OPENROUTER_MODEL=openai/gpt-4o-mini

# Space weather external APIs
NASA_API_KEY=DEMO_KEY

# Optional ESA SWE/HAPI supplementary provider
# Keep disabled unless you have a verified ESA/HAPI server, dataset, and credentials if required.
ESA_ENABLED=false
ESA_HAPI_BASE_URL=https://swe.ssa.esa.int/hapi
ESA_HAPI_DATASET_ID=spase://SSA/NumericalData/D3S/d3s_mtgs1_ngrm_science_ep_l1_bt_v1
ESA_HAPI_PARAMETERS=feio_1
ESA_HAPI_LOOKBACK_HOURS=24
ESA_ACCESS_TOKEN=
ESA_TOKEN_URL=https://sso.s2p.esa.int/realms/swe/protocol/openid-connect/token
ESA_CLIENT_ID=
ESA_CLIENT_SECRET=


# MCP gRPC
MCP_TRANSPORT=grpc
MCP_GRPC_HOST=geostorm-mcp-server
MCP_GRPC_PORT=50051
MCP_GRPC_TIMEOUT_SECONDS=30

# Optional MCP HTTP debug
MCP_HTTP_PORT=6274

# PostgreSQL
POSTGRES_DB=geostorm
POSTGRES_USER=geostorm
POSTGRES_PASSWORD=replace_me
DATABASE_URL=postgres://geostorm:replace_me@postgres:5432/geostorm
POSTGRES_PORT_HOST=5432

# RabbitMQ
RABBITMQ_USER=geostorm
RABBITMQ_PASSWORD=replace_me
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_URL=amqp://geostorm:replace_me@rabbitmq:5672/%2f

# Frontend -> AI server-side route
FASTAPI_URL=http://geostorm-ai-engine:8000/api/v1/insight

# Email / Notification
EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
ALERT_EMAIL_TO=

# App ports
FRONTEND_PORT=3000
AI_ENGINE_PORT=8000
MCP_GRPC_PORT_HOST=50051
MCP_HTTP_PORT_HOST=6274

# Gateway Authentication Settings
AUTH_ENABLED=true
AUTH_USERNAME=admin
AUTH_PASSWORD=replace_me_strong_password
AUTH_COOKIE_SECRET=geostorm_super_secret_session_key_32_chars_long
AUTH_COOKIE_NAME=geostorm_session

# Container images for docker-compose.images.yml
MCP_SERVER_IMAGE=ghcr.io/keremthedev/geostorm-mcp-server:latest
ALERT_SERVICE_IMAGE=ghcr.io/keremthedev/geostorm-alert-service:latest
FRONTEND_GATEWAY_IMAGE=ghcr.io/alperensarikavak/geostorm-frontend-gateway:latest
AI_ENGINE_IMAGE=ghcr.io/alperensarikavak/geostorm-ai-engine:latest
