# GeoStorm-AI canonical local Docker Compose environment example
# Copy to .env for local Docker Compose. Do not put real secrets in this file.

# Container images for docker-compose.images.yml
IMAGE_TAG=final-submission
GITHUB_CONTAINER_OWNER=replace_me
AI_ENGINE_IMAGE=ghcr.io/replace_me/geostorm-ai-engine:final-submission
MCP_SERVER_IMAGE=ghcr.io/replace_me/geostorm-mcp-server:final-submission
ALERT_SERVICE_IMAGE=ghcr.io/replace_me/geostorm-alert-service:final-submission
FRONTEND_GATEWAY_IMAGE=ghcr.io/replace_me/geostorm-frontend-gateway:final-submission

# LLM / AI
OPENROUTER_API_KEY=replace_me
OPENROUTER_MODEL=openai/gpt-4o-mini

# Space weather external APIs
NASA_API_KEY=DEMO_KEY

# MCP gRPC
MCP_TRANSPORT=grpc
MCP_GRPC_HOST=geostorm-mcp-server
MCP_GRPC_PORT=50051
MCP_GRPC_TIMEOUT_SECONDS=30

# Optional MCP HTTP debug
MCP_HTTP_PORT=6274

# PostgreSQL
POSTGRES_DB=geostorm
POSTGRES_USER=geostorm
POSTGRES_PASSWORD=replace_me
DATABASE_URL=postgres://geostorm:replace_me@postgres:5432/geostorm
POSTGRES_PORT_HOST=5432

# RabbitMQ
RABBITMQ_USER=geostorm
RABBITMQ_PASSWORD=replace_me
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_URL=amqp://geostorm:replace_me@rabbitmq:5672/%2f

# Frontend -> AI server-side route
FASTAPI_URL=http://geostorm-ai-engine:8000/api/v1/insight

# Email / Notification
EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
ALERT_EMAIL_TO=

# App ports
FRONTEND_PORT=3000
AI_ENGINE_PORT=8000
MCP_GRPC_PORT_HOST=50051
MCP_HTTP_PORT_HOST=6274
